flowchart LR

    %% ============================================================
    %% PROENG ARCHITECTURE
    %% Readable overview + concrete implementation map
    %% ============================================================

    subgraph SHELL["APPLICATION SHELL"]
        MA["MainApp<br/>QMainWindow facade"]
        ST["QStackedWidget<br/>lazy navigation host"]
    end

    subgraph ENTRY["UI ENTRYPOINTS"]
        NB["NavBar<br/>theme + help + navigation"]
        WS["WelcomeScreen<br/>launcher + project actions"]
    end

    subgraph CORE["CORE SERVICES"]
        TH["themes.py<br/>T() / set_theme() / cycle_theme()"]
        AP["AppProject<br/>save / load / restore .proeng"]
        BM["BaseModule<br/>get_state / set_state / refresh_theme / get_view"]
        UT["utils.py<br/>export helpers"]
    end

    subgraph MODULES["MODULE SYSTEM"]
        MW["Module wrappers<br/>11 BaseModule adapters"]
        VW["Inner widgets<br/>real visual editors"]
    end

    subgraph FLOWS["CROSS-CUTTING FLOWS"]
        LAZY["Lazy loading<br/>_get_or_create_module()"]
        PERSIST["Persistence flow<br/>get_state / set_state"]
        THEME["Theme propagation<br/>refresh_theme()"]
    end

    subgraph DETAIL["CONCRETE MODULE MAP"]
        WRAPS["Wrappers<br/>_FlowsheetModule, _GanttModule, _EAPModule, _BPMNModule,<br/>_CanvasModule, _IshikawaModule, _W5H2Module, _ModuloKanban,<br/>_ScrumModule, _PDCAModule, _ScriptModule"]
        WIDS["Widgets<br/>FlowsheetWidget, GanttWidget, EAPWidget, BPMNAutoWidget,<br/>PMCanvasWidget, IshikawaWidget, W5H2Widget, WidgetKanban,<br/>ScrumWidget, WidgetPDCAView, EditorInterpretadorWidget"]
    end

    %% ============================================================
    %% MAIN FLOW
    %% ============================================================
    NB -->|"commands"| MA
    WS -->|"opens / creates / loads"| MA
    MA -->|"hosts"| ST
    ST -->|"shows"| WS
    ST -->|"shows"| MW

    MA -->|"uses"| TH
    MA -->|"uses"| AP
    MA -->|"uses"| UT
    MA -->|"orchestrates"| LAZY

    LAZY -->|"instantiates on demand"| MW
    MW -.->|"implements"| BM
    MW -->|"wraps _inner"| VW

    AP -->|"persists module snapshots"| PERSIST
    PERSIST -->|"save / restore"| MW

    TH -->|"refreshes"| THEME
    THEME -->|"applies to"| NB
    THEME -->|"applies to"| WS
    THEME -->|"applies to"| MW

    UT -->|"exports from"| VW

    %% ============================================================
    %% DETAIL LINKS
    %% ============================================================
    MW --> WRAPS
    VW --> WIDS

    %% ============================================================
    %% NEO-BRUTALIST STYLES
    %% ============================================================
    classDef shell fill:#FFE500,stroke:#000000,stroke-width:8px,color:#000000,font-size:20px
    classDef entry fill:#C8FF00,stroke:#000000,stroke-width:8px,color:#000000,font-size:18px
    classDef core fill:#0057FF,stroke:#000000,stroke-width:8px,color:#FFFFFF,font-size:18px
    classDef module fill:#FF5500,stroke:#000000,stroke-width:8px,color:#FFFFFF,font-size:18px
    classDef flow fill:#00D5FF,stroke:#000000,stroke-width:8px,color:#000000,font-size:18px
    classDef detail fill:#FF006E,stroke:#000000,stroke-width:8px,color:#FFFFFF,font-size:17px

    class MA,ST shell
    class NB,WS entry
    class TH,AP,BM,UT core
    class MW,VW module
    class LAZY,PERSIST,THEME flow
    class WRAPS,WIDS detail

    style SHELL fill:#FFE500,stroke:#000000,stroke-width:10px,color:#000000,font-size:26px
    style ENTRY fill:#C8FF00,stroke:#000000,stroke-width:10px,color:#000000,font-size:26px
    style CORE fill:#0057FF,stroke:#000000,stroke-width:10px,color:#FFFFFF,font-size:26px
    style MODULES fill:#FF5500,stroke:#000000,stroke-width:10px,color:#FFFFFF,font-size:26px
    style FLOWS fill:#00D5FF,stroke:#000000,stroke-width:10px,color:#000000,font-size:26px
    style DETAIL fill:#FF006E,stroke:#000000,stroke-width:10px,color:#FFFFFF,font-size:26px
