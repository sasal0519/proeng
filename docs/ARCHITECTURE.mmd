%%{init: {
  "theme": "dark",
  "flowchart": { "curve": "basis", "nodeSpacing": 40, "rankSpacing": 56 },
  "themeVariables": {
    "background":         "#000000",
    "mainBkg":            "#000000",
    "edgeLabelBackground":"#000000",
    "clusterBkg":         "#111111",
    "clusterBorder":      "#ffffff",
    "lineColor":          "#ffffff",
    "titleColor":         "#ffffff",
    "nodeTextColor":      "#ffffff",
    "fontFamily":         "monospace",
    "fontSize":           "13px"
  }
}}%%
flowchart TB

  subgraph SHELL["APPLICATION SHELL"]
    MA(["MainApp · QMainWindow facade"])
    ST(["QStackedWidget · lazy nav host"])
  end

  subgraph ENTRY["UI LAYER"]
    NB["NavBar\nnavigation · theme · help"]
    WS["WelcomeScreen\nlauncher · project actions"]
  end

  subgraph CORE["CORE SERVICES"]
    TH{{"themes.py\nT() · set_theme() · cycle_theme()"}}
    AP[("AppProject\nJSON .proeng persistence")]
    BM[/"BaseModule\nget_state · set_state · refresh_theme"/]
    UT>"utils.py · export helpers"]
  end

  subgraph MODS["MODULE WRAPPERS  ×11"]
    direction LR
    FM["_FlowsheetModule"]
    GM["_GanttModule"]
    EM["_EAPModule"]
    BPM["_BPMNModule"]
    CM["_CanvasModule"]
    IM["_IshikawaModule"]
    WM["_W5H2Module"]
    KM["_ModuloKanban"]
    SM["_ScrumModule"]
    PM["_PDCAModule"]
    SYM["_ScriptModule"]
  end

  subgraph WIDS["INNER VISUAL WIDGETS"]
    direction LR
    FW(["FlowsheetWidget"])
    GW(["GanttWidget"])
    EW(["EAPWidget"])
    BW(["BPMNAutoWidget"])
    CW(["PMCanvasWidget"])
    IW(["IshikawaWidget"])
    WW(["W5H2Widget"])
    KW(["WidgetKanban"])
    SW(["ScrumWidget"])
    PW(["WidgetPDCAView"])
    YW(["EditorInterpretadorWidget"])
  end

  subgraph CROSS["CROSS-CUTTING FLOWS"]
    LAZY[/"Lazy loading\n_get_or_create_module()"/]
    PERSIST[/"Persistence flow\nget_state · set_state"/]
    THEMEFLOW[/"Theme propagation\nrefresh_theme()"/]
  end

  %% App / UI
  NB -->|"navigate / toggle theme"| MA
  WS -->|"open / new / load project"| MA
  MA -->|hosts| ST
  ST -->|shows| WS
  ST -->|shows| MODS

  %% Core wiring
  MA -->|uses| TH
  MA -->|uses| AP
  MA -->|uses| UT
  MA -->|orchestrates| LAZY

  %% Lazy → wrappers
  LAZY -->|"instantiates on demand"| MODS

  %% BaseModule contract
  MODS -.->|implements| BM

  %% Wrapper → inner widget
  FM --- FW
  GM --- GW
  EM --- EW
  BPM --- BW
  CM --- CW
  IM --- IW
  WM --- WW
  KM --- KW
  SM --- SW
  PM --- PW
  SYM --- YW

  %% Persistence
  AP <-->|"save · restore"| PERSIST
  PERSIST -->|"state snapshots"| MODS

  %% Theme propagation
  TH -->|refresh| THEMEFLOW
  THEMEFLOW -->|"applies to"| NB
  THEMEFLOW -->|"applies to"| WS
  THEMEFLOW -->|"applies to"| MODS

  %% Export helpers
  UT -->|export| FW & GW & EW & IW & WW & PW

  %% Force all edges white
  linkStyle default stroke:#ffffff,stroke-width:1.8px,fill:none

  %% Node styles — fills escuros com bordas brancas
  classDef shell  fill:#2a2200,stroke:#ffffff,stroke-width:3px,color:#FFE500,font-weight:600
  classDef entry  fill:#1a2b00,stroke:#ffffff,stroke-width:2px,color:#C8FF00
  classDef core   fill:#001a4d,stroke:#ffffff,stroke-width:3px,color:#7ab3ff,font-weight:600
  classDef wrap   fill:#3a1200,stroke:#ffffff,stroke-width:2px,color:#ff9066
  classDef widget fill:#3a0020,stroke:#ffffff,stroke-width:2px,color:#ff66b0
  classDef cross  fill:#003a40,stroke:#ffffff,stroke-width:2px,color:#00D5FF

  class MA,ST shell
  class NB,WS entry
  class TH,AP,BM,UT core
  class FM,GM,EM,BPM,CM,IM,WM,KM,SM,PM,SYM wrap
  class FW,GW,EW,BW,CW,IW,WW,KW,SW,PW,YW widget
  class LAZY,PERSIST,THEMEFLOW cross