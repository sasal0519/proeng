    UT -->|"export helpers"| IM
    UT -->|"export helpers"| WM
    UT -->|"export helpers"| PM

    %% ============================================================
    %% STYLES - NEO BRUTALIST
    %% ============================================================
    classDef app fill:#FFE500,stroke:#000000,stroke-width:8px,color:#000000,font-size:20px
    classDef ui fill:#C8FF00,stroke:#000000,stroke-width:7px,color:#000000,font-size:18px
    classDef core fill:#0057FF,stroke:#000000,stroke-width:8px,color:#ffffff,font-size:18px
    classDef wrap fill:#FF5500,stroke:#000000,stroke-width:7px,color:#ffffff,font-size:17px
    classDef widget fill:#FF006E,stroke:#000000,stroke-width:7px,color:#ffffff,font-size:17px
    classDef cross fill:#00D5FF,stroke:#000000,stroke-width:7px,color:#000000,font-size:17px

    class MA,ST app
    class NB,WS ui
    class TH,AP,BM,UT core
    class FM,GM,EM,BPM,CM,IM,WM,KM,SM,PM,SYM wrap
    class FW,GW,EW,BW,CW,IW,WW,KW,SW,PW,YW widget
    class PERSIST,THEMEFLOW,LAZY cross

    style APP fill:#FFE500,stroke:#000000,stroke-width:10px,color:#000000,font-size:26px
    style UI fill:#C8FF00,stroke:#000000,stroke-width:10px,color:#000000,font-size:26px
    style CORE fill:#0057FF,stroke:#000000,stroke-width:10px,color:#ffffff,font-size:26px
    style WRAPPERS fill:#FF5500,stroke:#000000,stroke-width:10px,color:#ffffff,font-size:26px
    style WIDGETS fill:#FF006E,stroke:#000000,stroke-width:10px,color:#ffffff,font-size:26px
    style CROSSCUT fill:#00D5FF,stroke:#000000,stroke-width:10px,color:#000000,font-size:26px
