flowchart TB

    %% ============================================================
    %% PROENG ARCHITECTURE
    %% Shell -> Core -> Module Wrappers -> Inner Widgets
    %% ============================================================

    subgraph APP["APPLICATION SHELL"]
        MA["MainApp<br/>QMainWindow facade"]
        ST["QStackedWidget<br/>lazy navigation host"]
    end

    subgraph UI["UI ENTRYPOINTS"]
        NB["NavBar<br/>navigation + theme + help"]
        WS["WelcomeScreen<br/>home + launcher"]
    end

    subgraph CORE["CORE SERVICES"]
        TH["themes.py<br/>T() + set_theme() + cycle_theme()"]
        AP["AppProject<br/>JSON .proeng persistence"]
        BM["BaseModule<br/>get_state / set_state / refresh_theme / get_view"]
        UT["utils.py<br/>export + helpers"]
    end

    subgraph WRAPPERS["MODULE WRAPPERS (BaseModule)"]
        FM["_FlowsheetModule"]
        GM["_GanttModule"]
        EM["_EAPModule"]
        BPM["_BPMNModule"]
        CM["_CanvasModule"]
        IM["_IshikawaModule"]
        WM["_W5H2Module"]
        KM["_ModuloKanban"]
        SM["_ScrumModule"]
        PM["_PDCAModule"]
        SYM["_ScriptModule"]
    end

    subgraph WIDGETS["INNER VISUAL WIDGETS"]
        FW["FlowsheetWidget"]
        GW["GanttWidget"]
        EW["EAPWidget"]
        BW["BPMNAutoWidget"]
        CW["PMCanvasWidget"]
        IW["IshikawaWidget"]
        WW["W5H2Widget"]
        KW["WidgetKanban"]
        SW["ScrumWidget"]
        PW["WidgetPDCAView"]
        YW["EditorInterpretadorWidget"]
    end

    subgraph CROSSCUT["CROSS-CUTTING FLOWS"]
        PERSIST["Project lifecycle<br/>save / load / restore module state"]
        THEMEFLOW["Theme propagation<br/>NavBar -> MainApp -> widgets + scenes"]
        LAZY["Lazy loading<br/>_get_or_create_module() on first access"]
    end

    %% ============================================================
    %% APP / UI RELATIONSHIPS
    %% ============================================================
    MA -->|"owns"| NB
    MA -->|"owns"| WS
    MA -->|"hosts"| ST

    NB -->|"navigate / request example / toggle theme"| MA
    WS -->|"open_module / new_project / open_project"| MA

    MA -->|"creates on demand"| LAZY
    LAZY --> FM
    LAZY --> GM
    LAZY --> EM
    LAZY --> BPM
    LAZY --> CM
    LAZY --> IM
    LAZY --> WM
    LAZY --> KM
    LAZY --> SM
    LAZY --> PM
    LAZY --> SYM

    ST -->|"shows"| WS
    ST -->|"shows"| FM
    ST -->|"shows"| GM
    ST -->|"shows"| EM
    ST -->|"shows"| BPM
    ST -->|"shows"| CM
    ST -->|"shows"| IM
    ST -->|"shows"| WM
    ST -->|"shows"| KM
    ST -->|"shows"| SM
    ST -->|"shows"| PM
    ST -->|"shows"| SYM

    %% ============================================================
    %% CORE RELATIONSHIPS
    %% ============================================================
    MA -->|"uses"| TH
    MA -->|"uses"| AP
    MA -->|"uses"| UT

    NB -->|"requests theme refresh"| TH
    WS -->|"reads previews + opens modules"| MA

    PERSIST --> AP
    MA -->|"coordinates"| PERSIST

    THEMEFLOW --> TH
    MA -->|"propagates"| THEMEFLOW
    NB -->|"starts"| THEMEFLOW

    %% ============================================================
    %% BASEMODULE CONTRACT
    %% ============================================================
    FM -.->|"implements"| BM
    GM -.->|"implements"| BM
    EM -.->|"implements"| BM
    BPM -.->|"implements"| BM
    CM -.->|"implements"| BM
    IM -.->|"implements"| BM
    WM -.->|"implements"| BM
    KM -.->|"implements"| BM
    SM -.->|"implements"| BM
    PM -.->|"implements"| BM
    SYM -.->|"implements"| BM

    %% ============================================================
    %% WRAPPER -> INNER WIDGET
    %% ============================================================
    FM -->|"wraps _inner"| FW
    GM -->|"wraps _inner"| GW
    EM -->|"wraps _inner"| EW
    BPM -->|"wraps _inner"| BW
    CM -->|"wraps _inner"| CW
    IM -->|"wraps _inner"| IW
    WM -->|"wraps _inner"| WW
    KM -->|"wraps _inner"| KW
    SM -->|"wraps _inner"| SW
    PM -->|"wraps _inner"| PW
    SYM -->|"wraps _inner"| YW

    %% ============================================================
    %% CROSS-CUTTING DEPENDENCIES
    %% ============================================================
    FM -->|"get_state / set_state"| AP
    GM -->|"get_state / set_state"| AP
    EM -->|"get_state / set_state"| AP
    BPM -->|"get_state / set_state"| AP
    CM -->|"get_state / set_state"| AP
    IM -->|"get_state / set_state"| AP
    WM -->|"get_state / set_state"| AP
    KM -->|"get_state / set_state"| AP
    SM -->|"get_state / set_state"| AP
    PM -->|"get_state / set_state"| AP
    SYM -->|"get_state / set_state"| AP

    TH -->|"refresh_theme"| NB
    TH -->|"refresh_theme"| WS
    TH -->|"refresh_theme"| FM
    TH -->|"refresh_theme"| GM
    TH -->|"refresh_theme"| EM
    TH -->|"refresh_theme"| BPM
    TH -->|"refresh_theme"| CM
    TH -->|"refresh_theme"| IM
    TH -->|"refresh_theme"| WM
    TH -->|"refresh_theme"| KM
    TH -->|"refresh_theme"| SM
    TH -->|"refresh_theme"| PM
    TH -->|"refresh_theme"| SYM

    UT -->|"export helpers"| FM
