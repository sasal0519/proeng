%%{init: {
  "theme": "base",
  "flowchart": { "curve": "basis", "nodeSpacing": 40, "rankSpacing": 56 },
  "themeVariables": {
    "primaryColor":       "#FFE500",
    "primaryTextColor":   "#000000",
    "primaryBorderColor": "#000000",
    "secondaryColor":     "#C8FF00",
    "tertiaryColor":      "#D6E8FF",
    "lineColor":          "#000000",
    "edgeLabelBackground":"#ffffff",
    "clusterBkg":         "#f7f7f5",
    "clusterBorder":      "#000000",
    "titleColor":         "#000000",
    "fontFamily":         "monospace",
    "fontSize":           "13px"
  }
}}%%
flowchart TB

  subgraph SHELL["APPLICATION SHELL"]
    MA(["MainApp · QMainWindow facade"])
    ST(["QStackedWidget · lazy nav host"])
  end

  subgraph ENTRY["UI LAYER"]
    NB["NavBar\nnavigation · theme · help"]
    WS["WelcomeScreen\nlauncher · project actions"]
  end

  subgraph CORE["CORE SERVICES"]
    TH{{"themes.py\nT() · set_theme() · cycle_theme()"}}
    AP[("AppProject\nJSON .proeng persistence")]
    BM[/"BaseModule\nget_state · set_state · refresh_theme · get_view"/]
    UT>"utils.py · export helpers"]
  end

  subgraph MODS["MODULE WRAPPERS  ×11"]
    direction LR
    FM["_FlowsheetModule"]
    GM["_GanttModule"]
    EM["_EAPModule"]
    BPM["_BPMNModule"]
    CM["_CanvasModule"]
    IM["_IshikawaModule"]
    WM["_W5H2Module"]
    KM["_ModuloKanban"]
    SM["_ScrumModule"]
    PM["_PDCAModule"]
    SYM["_ScriptModule"]
  end

  subgraph WIDS["INNER VISUAL WIDGETS"]
    direction LR
    FW(["FlowsheetWidget"])
    GW(["GanttWidget"])
    EW(["EAPWidget"])
    BW(["BPMNAutoWidget"])
    CW(["PMCanvasWidget"])
    IW(["IshikawaWidget"])
    WW(["W5H2Widget"])
    KW(["WidgetKanban"])
    SW(["ScrumWidget"])
    PW(["WidgetPDCAView"])
    YW(["EditorInterpretadorWidget"])
  end

  subgraph CROSS["CROSS-CUTTING FLOWS"]
    LAZY[/"Lazy loading\n_get_or_create_module()"/]
    PERSIST[/"Persistence flow\nget_state · set_state"/]
    THEMEFLOW[/"Theme propagation\nrefresh_theme()"/]
  end

  %% ── App / UI ──────────────────────────────────────────────────
  NB -->|"navigate / toggle theme"| MA
  WS -->|"open / new / load project"| MA
  MA -->|hosts| ST
  ST -->|shows| WS
  ST -->|shows| MODS

  %% ── Core wiring ───────────────────────────────────────────────
  MA -->|uses| TH
  MA -->|uses| AP
  MA -->|uses| UT
  MA -->|orchestrates| LAZY

  %% ── Lazy → wrappers ───────────────────────────────────────────
  LAZY -->|"instantiates on demand"| MODS

  %% ── BaseModule contract ───────────────────────────────────────
  MODS -.->|implements| BM

  %% ── Wrapper → inner widget ────────────────────────────────────
  FM --- FW
  GM --- GW
  EM --- EW
  BPM --- BW
  CM --- CW
  IM --- IW
  WM --- WW
  KM --- KW
  SM --- SW
  PM --- PW
  SYM --- YW

  %% ── Persistence ───────────────────────────────────────────────
  AP <-->|save · restore| PERSIST
  PERSIST -->|state snapshots| MODS

  %% ── Theme propagation ─────────────────────────────────────────
  TH -->|refresh| THEMEFLOW
  THEMEFLOW -->|applies to| NB
  THEMEFLOW -->|applies to| WS
  THEMEFLOW -->|applies to| MODS

  %% ── Export helpers ────────────────────────────────────────────
  UT -->|export| FW & GW & EW & IW & WW & PW

  %% ── Styles ────────────────────────────────────────────────────
  classDef shell  fill:#FFE500,stroke:#000,stroke-width:4px,color:#000,font-weight:600
  classDef entry  fill:#C8FF00,stroke:#000,stroke-width:3px,color:#000
  classDef core   fill:#0057FF,stroke:#000,stroke-width:3px,color:#fff,font-weight:600
  classDef wrap   fill:#FF5500,stroke:#000,stroke-width:2px,color:#fff
  classDef widget fill:#FF006E,stroke:#000,stroke-width:2px,color:#fff
  classDef cross  fill:#00D5FF,stroke:#000,stroke-width:2px,color:#000

  class MA,ST shell
  class NB,WS entry
  class TH,AP,BM,UT core
  class FM,GM,EM,BPM,CM,IM,WM,KM,SM,PM,SYM wrap
  class FW,GW,EW,BW,CW,IW,WW,KW,SW,PW,YW widget
  class LAZY,PERSIST,THEMEFLOW cross